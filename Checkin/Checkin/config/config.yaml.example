server:
  name: "appname"
  mode: "dev"
  port: 8000
  version: "v0.0.1"

snowflake:
  start_time: "2025-07-01"
  machine_id: 1

jwt:
  access_secret: "your-access-secret"
  refresh_secret: "your-refresh-secret"
  access_expire_seconds: 3600
  refresh_expire_seconds: 86400

log:
  level: "info"
  filename: "log/server.log"
  max_size: 200
  max_age: 30
  max_backups: 7

mysql:
  host: 127.0.0.1
  port: 3306
  user: "root"
  password: "your-mysql-password"
  dbname: "checkin"
  max_open_conns: 200
  max_idle_conns: 50
  max_lifetime: 1h 

redis:
  host: 127.0.0.1
  port: 6379
  password: ""
  db: 0
  pool_size: 10

llm:
  api_key: "your-llm-api-key"
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  model: "qwen-plus"
